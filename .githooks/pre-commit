#!/bin/bash
set -euo pipefail

AUTHOR_EMAIL=$(git config user.email)
if [[ ! "$AUTHOR_EMAIL" =~ @(netapp\.com|gmail\.com)$ ]]; then
  echo "❌ ERROR: Author email must be @netapp.com or @gmail.com"
  echo "   Current: $AUTHOR_EMAIL"
  exit 1
fi

if command -v gitleaks &> /dev/null; then
  echo "🔍 Running gitleaks on staged files..."
  gitleaks protect --staged --config .gitleaks.toml --no-banner
fi

WORKFLOW_FILES=$(git diff --cached --name-only -- '.github/workflows/*.yml' '.github/workflows/*.yaml' 2>/dev/null || true)
if [[ -n "$WORKFLOW_FILES" ]] && command -v zizmor &> /dev/null; then
  echo "🔍 Running zizmor on changed workflow files..."
  echo "$WORKFLOW_FILES" | xargs zizmor
fi

echo "✅ Pre-commit checks passed"
