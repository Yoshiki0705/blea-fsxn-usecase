{
  "name": "blea-fsxn-usecase",
  "version": "0.1.0",
  "description": "BLEA guest system use case: Amazon FSx for NetApp ONTAP with data analytics and AI",
  "private": true,
  "engines": {
    "node": ">=22",
    "npm": ">=8.1.0"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint --fix .",
    "lint:ci": "eslint .",
    "format": "prettier --write .",
    "format:ci": "prettier --check .",
    "clean": "rm -rf cdk.out usecases/*/cdk.out",
    "verify": "bash shared/scripts/verify-stack.sh",
    "cleanup": "bash shared/scripts/cleanup-fsxn-stack.sh"
  },
  "workspaces": [
    "usecases/blea-guest-fsxn-data-analytics-sample",
    "usecases/guest-fsxn-cyber-resilience-sample",
    "usecases/blea-guest-fsxn-flexcache-sample",
    "usecases/blea-guest-fsxn-modernization-sample",
    "shared"
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.19.20",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.60.1"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.236.0",
    "constructs": "^10.3.0"
  }
}
